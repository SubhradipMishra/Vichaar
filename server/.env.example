# Server Configuration
PORT=7070
FRONTEND_URL=http://localhost:5173

# Database & Cache
DB_URL=mongodb://localhost:27017/Vichaar
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=your_jwt_secret_here
OAUTH_CLIENT=your_google_oauth_client_id

# Email (SMTP - Brevo)
